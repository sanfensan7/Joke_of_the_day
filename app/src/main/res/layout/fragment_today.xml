<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_today_gradient"
    android:paddingStart="20dp"
    android:paddingTop="16dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <View
        android:id="@+id/decorOrbTop"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:alpha="0.75"
        android:background="@drawable/bg_decor_orb_top"
        android:importantForAccessibility="no"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/decorOrbBottom"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:alpha="0.7"
        android:background="@drawable/bg_decor_orb_bottom"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/titleToday"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today"
        android:textColor="@color/ios_text_primary"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/subtitleToday"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="轻戳宠物，收获一条今日冷笑话"
        android:textColor="@color/ios_text_secondary"
        android:textSize="13sp"
        app:layout_constraintEnd_toStartOf="@id/btnRefreshPet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleToday" />

    <ImageButton
        android:id="@+id/btnRefreshPet"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_ios_round_icon_btn"
        android:contentDescription="换一只宠物"
        android:padding="10dp"
        android:src="@drawable/ic_refresh"
        android:tint="@color/ios_text_primary"
        app:layout_constraintBottom_toBottomOf="@id/titleToday"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/titleToday" />

    <TextView
        android:id="@+id/levelText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_ios_chip"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp"
        android:text="Lv. 1"
        android:textColor="@color/ios_text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitleToday" />

    <TextView
        android:id="@+id/petNameText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_ios_chip"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp"
        android:text="机器人"
        android:textColor="@color/ios_text_secondary"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@id/levelText"
        app:layout_constraintStart_toEndOf="@id/levelText"
        app:layout_constraintTop_toTopOf="@id/levelText" />

    <com.example.joke_of_the_day.ui.pet.PetAvatar
        android:id="@+id/petAvatar"
        android:layout_width="262dp"
        android:layout_height="262dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_ios_glass_card"
        android:elevation="6dp"
        android:padding="20dp"
        app:layout_constraintBottom_toTopOf="@+id/jokeCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/levelText"
        app:layout_constraintVertical_chainStyle="packed"
        tools:ignore="MissingConstraints" />

    <androidx.cardview.widget.CardView
        android:id="@+id/jokeCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_ios_glass_card"
        app:cardBackgroundColor="@color/ios_card"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:cardUseCompatPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/petAvatar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="22dp">

            <TextView
                android:id="@+id/jokeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ios_chip"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:text="TODAY JOKE"
                android:textAllCaps="true"
                android:textColor="@color/ios_accent"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/jokeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:lineSpacingExtra="5dp"
                android:text="测试笑话"
                android:textColor="@color/ios_text_primary"
                android:textSize="19sp"
                android:textStyle="normal" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>